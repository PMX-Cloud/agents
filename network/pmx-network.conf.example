[backend]
url = "wss://api.pmxcloud.example/ws/agent/network"
# auth_token = "pmxagent_xxx"

[identity]
cert = "/etc/pmx-cloud/pmx-network/client.crt"
key = "/etc/pmx-cloud/pmx-network/client.key"

[keyset]
path = "/etc/pmx-cloud/keyset.pub"

[wireguard]
key_file = "/var/lib/pmx-cloud/network/wg.key"
listen_port_range = [51820, 51830]
max_peers_per_host = 256
interface = "pmxwg0"

[nftables]
ruleset_dir = "/etc/nftables.d/pmx"
max_rules_per_host = 10000

[isolation]
default_drop_input = true
allow_ssh_from = []

[state]
dir = "/var/lib/pmx-cloud/network"
