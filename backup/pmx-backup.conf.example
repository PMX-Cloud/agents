[backend]
url = "wss://api.pmxcloud.example/ws/agent/backup"
ca_cert = "/etc/pmx-cloud/backend-ca.crt"

[identity]
cert = "/etc/pmx-cloud/pmx-backup/client.crt"
key = "/etc/pmx-cloud/pmx-backup/client.key"

[keyset]
path = "/etc/pmx-cloud/keyset.pub"

[storage]
archive_roots = ["/var/lib/vz/dump", "/mnt/backups"]

[vzdump]
binary = "/usr/sbin/vzdump"
qm_binary = "/usr/sbin/qm"
qmrestore_binary = "/usr/sbin/qmrestore"
pct_binary = "/usr/sbin/pct"
tar_binary = "/usr/bin/tar"
pbs_binary = "/usr/bin/proxmox-backup-client"

[limits]
max_concurrent_jobs = 2
max_concurrent_syncs = 4
